    "desktop:state-test": "node scripts/desktop-state-tests.mjs",
    "workspace:dev": "pnpm run desktop:dev",
    "prepare:workspace": "pnpm --filter @a3s-lab/agent-planning --filter @a3s-lab/ocr --filter @a3s-lab/ooxml build",
    "workspace:build": "pnpm run prepare:workspace && pnpm run desktop:build",
    "desktop:prepare-dist": "node -e \"console.log('desktop workspace assets are emitted to dist/workspace; public/workspace is no longer mutated')\"",
    "build": "pnpm run workspace:build",
    "preview": "rsbuild preview",
    "format": "biome format --write ."
