# internShannon Desktop shell development commands

# Default: show available commands
default:
    @just --list

# Install frontend dependencies
install:
    pnpm install

# Start Tauri shell with the SPA dev server
dev:
    pnpm tauri:dev

# Build the Tauri desktop app bundle used for local verification
build:
    pnpm build

# Build release installers such as DMG with a standalone sidecar
bundle *args:
    pnpm tauri:bundle -- {{args}}

# Sync backend-owned embedded core skills into desktop resources
sync-core-skills:
    pnpm sync:core-skills

# Check that embedded core skills and desktop resources are in sync
check-core-skills:
    pnpm check:core-skills

# Validate the staged bundled a3s-box resources
check-box-resources:
    pnpm check:box-resources

# Validate bundled NestJS sidecar resources
check-sidecar-resources:
    pnpm check:sidecar-resources

# Validate sidecar release standalone readiness
check-standalone-sidecar:
    pnpm check:standalone-sidecar

# Build the desktop app and validate staged bundled a3s-box resources
tauri-build-validated:
    pnpm tauri:build:validated

# Clean build artifacts and node_modules
clean:
    pnpm clean
