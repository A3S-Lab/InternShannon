{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "internShannon",
  "version": "0.2.1",
  "identifier": "com.a3s.internshannon",
  "build": {
    "beforeDevCommand": "pnpm --filter @internshannon/web workspace:dev",
    "devUrl": "http://127.0.0.1:5000",
    "beforeBuildCommand": "pnpm --filter @internshannon/sidecar build && pnpm --filter @internshannon/web workspace:build && pnpm stage:sidecar",
    "frontendDist": "../../web/dist/workspace"
  },
  "app": {
    "windows": [
      {
        "title": "internShannon",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sidecar/": "",
      "resources/node/": "node/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxNUQ4QjEzRDlEMTE1NEEKUldSS0ZkSFpFNHRka2ZhZVJPUU13RnBFb3VDODFEaFVtTUswa0NnK1ZBajJlc2FLTGR3dFlmZkUK",
      "endpoints": [
        "https://github.com/A3S-Lab/internShannon/releases/latest/download/latest.json"
      ]
    }
  }
}
