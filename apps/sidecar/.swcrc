{
    "jsc": {
        "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
        },
        "target": "es2024",
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
        },
        "keepClassNames": true
    },
    "module": {
        "type": "commonjs"
    },
    "sourceMaps": true
}
