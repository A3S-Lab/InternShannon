{
    "name": "@internshannon/sidecar",
    "version": "1.0.0",
    "description": "Production-ready NestJS API with Domain-Driven Design and Clean Architecture",
    "author": "",
    "private": true,
    "license": "MIT",
    "scripts": {
        "clean:dist": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "prepare:workspace": "pnpm --filter @a3s-lab/agent-planning --filter @a3s-lab/lark --filter @a3s-lab/ocr build",
        "build": "pnpm prepare:workspace && node scripts/build-desktop-sidecar.mjs",
        "ddd:check": "node scripts/check-ddd-boundaries.mjs",
        "format": "biome format --write src scripts test",
        "format:check": "biome format src scripts test",
        "lint": "biome lint --write src scripts test",
        "lint:check": "pnpm ddd:check && biome lint src scripts test && pnpm sql:check",
        "sql:check": "node ../../scripts/check-sql-style.mjs && node --test ../../scripts/check-sql-style.test.mjs",
        "start": "pnpm build && node dist/main",
        "start:dev": "pnpm build && node dist/main",
        "start:dev:fast": "node scripts/build-desktop-sidecar.mjs && node dist/main",
        "start:debug": "pnpm build && node --inspect dist/main",
        "start:prod": "node dist/main",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@a3s-lab/acl": "^0.2.1",
        "@a3s-lab/agent-planning": "workspace:*",
        "@a3s-lab/code": "4.2.1",
        "@a3s-lab/lark": "workspace:*",
        "@a3s-lab/ocr": "workspace:*",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/cqrs": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/platform-socket.io": "^11.1.19",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/terminus": "^11.0.0",
        "@nestjs/websockets": "^11.1.19",
        "@octokit/rest": "^22.0.1",
        "art-template": "^4.13.4",
        "axios": "^1.7.0",
        "chokidar": "^4.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "dotenv": "17.4.1",
        "dotenv-expand": "12.0.3",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "js-yaml": "^4.1.1",
        "jszip": "^3.10.1",
        "lru-cache": "11.2.5",
        "pdf-parse": "^2.4.5",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "simple-git": "^3.27.0",
        "socket.io": "^4.8.3",
        "ssh2": "^1.17.0",
        "swagger-ui-dist": "^5.32.4",
        "tar-stream": "^3.1.7",
        "uuid": "^9.0.0",
        "xlsx": "^0.18.5",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@swc/cli": "^0.7.10",
        "@swc/core": "^1.15.11",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.0.0",
        "@types/ssh2": "^1.15.5",
        "jest": "^29.5.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": "./tsconfig.spec.json"
                }
            ]
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node",
        "maxWorkers": "50%",
        "workerIdleMemoryLimit": "1GB",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/$1",
            "^@a3s-lab/ocr$": "<rootDir>/../../../packages/ocr/src"
        }
    }
}
