{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "Node16",
        "moduleResolution": "Node16",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "composite": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "strict": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "types": [
            "node"
        ],
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.spec.ts",
        "**/*.test.ts"
    ]
}
