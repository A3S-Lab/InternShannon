{
    "name": "@a3s-lab/ooxml",
    "version": "0.0.1",
    "description": "OOXML import/export adapters for Univer snapshots",
    "author": "ZhiXiao-Lin",
    "license": "MIT",
    "keywords": [
        "ooxml",
        "office",
        "docx",
        "pptx",
        "xlsx",
        "univer"
    ],
    "source": "./src/index.ts",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./docx": {
            "import": "./dist/docx/index.js",
            "require": "./dist/docx/index.js",
            "types": "./dist/docx/index.d.ts"
        },
        "./pptx": {
            "import": "./dist/pptx/index.js",
            "require": "./dist/pptx/index.js",
            "types": "./dist/pptx/index.d.ts"
        },
        "./capabilities": {
            "import": "./dist/shared/capabilities.js",
            "require": "./dist/shared/capabilities.js",
            "types": "./dist/shared/capabilities.d.ts"
        },
        "./xlsx": {
            "import": "./dist/xlsx/index.js",
            "require": "./dist/xlsx/index.js",
            "types": "./dist/xlsx/index.d.ts"
        },
        "./univer": {
            "import": "./dist/univer/index.js",
            "require": "./dist/univer/index.js",
            "types": "./dist/univer/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "jest",
        "test:cov": "jest --coverage",
        "clean": "rimraf dist && rimraf node_modules",
        "prepublishOnly": "pnpm run build"
    },
    "dependencies": {
        "@xmldom/xmldom": "^0.8.11",
        "docx": "^9.6.1",
        "jszip": "^3.10.1",
        "mammoth": "^1.12.0",
        "xlsx": "^0.18.5"
    },
    "peerDependencies": {
        "@univerjs/core": "^0.24.0",
        "@univerjs/slides": "^0.24.0"
    },
    "devDependencies": {
        "@univerjs/core": "^0.24.0",
        "@univerjs/slides": "^0.24.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^22.7.9",
        "jest": "^29.5.0",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.1.0",
        "typescript": "^5.1.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": {
                        "types": [
                            "node",
                            "jest"
                        ]
                    }
                }
            ]
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
