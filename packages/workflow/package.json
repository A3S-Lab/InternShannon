{
  "name": "@a3s-lab/workflow",
  "version": "1.0.0",
  "description": "Workflow engine package for orchestrating Package-based workflows",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./engine": "./dist/engine/index.js",
    "./domain": "./dist/domain/index.js",
    "./interfaces": "./dist/interfaces/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/cqrs": "^11.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/__test-setup__/jest.env.ts"],
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/__tests__/**",
      "!**/node_modules/**"
    ]
  }
}
