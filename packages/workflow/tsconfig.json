{
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "module": "commonjs",
        "target": "es2022",
        "lib": [
            "es2022"
        ],
        "moduleResolution": "node",
        "types": [
            "node",
            "jest"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/**/__tests__/**",
        "src/**/*.spec.ts",
        "**/__tests__/**",
        "**/*.spec.ts",
        "**/*.test.ts"
    ]
}
