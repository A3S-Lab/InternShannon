{
  "name": "@shuxiaoan/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop and sidecar workspace",
  "scripts": {
    "build": "pnpm --filter @shuxiaoan/sidecar build",
    "desktop:doctor": "pnpm --filter @shuxiaoan/desktop doctor",
    "desktop:stage-sidecar": "pnpm --filter @shuxiaoan/desktop stage:sidecar",
    "sidecar:build": "pnpm --filter @shuxiaoan/sidecar build",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "typescript": "^5.1.3"
  }
}
